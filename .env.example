# MediSync AI — Environment Variables Template
# Copy this file to .env and fill in the required values

# ── Required ───────────────────────────────────────────────────────────────
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/
JWT_SECRET_KEY=your-super-secret-jwt-key-minimum-32-characters

# ── Optional AI Keys ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# ── Database ───────────────────────────────────────────────────────────────
MONGODB_DB_NAME=medisync_db
REDIS_URL=redis://localhost:6379

# ── Application ────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# ── AI Configuration ───────────────────────────────────────────────────────
SPEECH_PROVIDER=whisper
WHISPER_MODEL_SIZE=base
NLP_MODEL=en_core_web_sm

# ── Feature Flags ──────────────────────────────────────────────────────────
USE_MOCK_AI=false
ENABLE_SPEECH_PROCESSING=true
ENABLE_AI_PRIORITIZATION=true
ENABLE_TIME_PREDICTION=true

# ── Security Thresholds ────────────────────────────────────────────────────
CRITICAL_SYMPTOM_THRESHOLD=0.8
MODERATE_SYMPTOM_THRESHOLD=0.5
